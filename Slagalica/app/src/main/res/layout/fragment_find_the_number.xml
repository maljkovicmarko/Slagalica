<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="Fragments.FindTheNumberFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/moj_broj_title"
            android:textSize="30sp"
            android:textStyle="bold"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="20dp" />

        <TextView
            android:id="@+id/timerText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/timer_placeholder"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="20dp" />

        <TextView
            android:id="@+id/roundText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Runda: 1/2"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/playerTurnText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Na potezu: Igrač 1"
            android:textSize="18sp"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/target_number_label"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/targetNumberText"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:text="100"
            android:textSize="32sp"
            android:textStyle="bold"
            android:gravity="center"
            android:background="@android:color/darker_gray"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/stopTargetButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/stop"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/numbers_label"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="3"
            android:layout_marginBottom="12dp">

            <Button
                android:id="@+id/numberOneButton"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_columnWeight="1"
                android:text="0" />

            <Button
                android:id="@+id/numberTwoButton"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_columnWeight="1"
                android:text="0" />

            <Button
                android:id="@+id/numberThreeButton"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_columnWeight="1"
                android:text="0" />

            <Button
                android:id="@+id/numberFourButton"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_columnWeight="1"
                android:text="0" />

            <Button
                android:id="@+id/numberFiveButton"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_columnWeight="1"
                android:text="0" />

            <Button
                android:id="@+id/numberSixButton"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_columnWeight="1"
                android:text="0" />

        </GridLayout>

        <Button
            android:id="@+id/stopNumbersButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/stop"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/expression_label"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/expressionInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/expression_hint"
            android:inputType="text"
            android:layout_marginBottom="16dp" />

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="4"
            android:layout_marginBottom="20dp">

            <Button
                android:id="@+id/openParenthesisButton"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_columnWeight="1"
                android:text="(" />

            <Button
                android:id="@+id/closeParenthesisButton"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_columnWeight="1"
                android:text=")" />

            <Button
                android:id="@+id/plusButton"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_columnWeight="1"
                android:text="+" />

            <Button
                android:id="@+id/minusButton"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_columnWeight="1"
                android:text="-" />

            <Button
                android:id="@+id/multiplyButton"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_columnWeight="1"
                android:text="*" />

            <Button
                android:id="@+id/divideButton"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_columnWeight="1"
                android:text="/" />

            <Button
                android:id="@+id/clearButton"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_columnWeight="1"
                android:text="@string/clear" />

            <Button
                android:id="@+id/submitExpressionButton"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_columnWeight="1"
                android:text="@string/submit_answer" />

        </GridLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/score_label"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/playerOneScoreText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/player_one_score"
            android:textSize="18sp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/playerTwoScoreText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/player_two_score"
            android:textSize="18sp" />

    </LinearLayout>

</ScrollView>