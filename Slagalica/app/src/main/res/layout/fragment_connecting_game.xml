<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="Fragments.ConnectingGameFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/spojnice_title"
            android:textSize="30sp"
            android:textStyle="bold"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="20dp" />

        <TextView
            android:id="@+id/timerText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="30s"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/roundText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Runda: 1/2"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/playerTurnText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Na potezu: Igrač 1"
            android:textSize="18sp"
            android:gravity="center"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/criterion_label"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/criterionText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/criterion_placeholder"
            android:padding="12dp"
            android:background="@android:color/darker_gray"
            android:layout_marginBottom="20dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/left_column_label"
                android:textStyle="bold"
                android:gravity="center" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/right_column_label"
                android:textStyle="bold"
                android:gravity="center" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginEnd="8dp">

                <Button
                    android:id="@+id/leftOneButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Pojam 1"
                    android:layout_marginBottom="8dp" />

                <Button
                    android:id="@+id/leftTwoButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Pojam 2"
                    android:layout_marginBottom="8dp" />

                <Button
                    android:id="@+id/leftThreeButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Pojam 3"
                    android:layout_marginBottom="8dp" />

                <Button
                    android:id="@+id/leftFourButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Pojam 4"
                    android:layout_marginBottom="8dp" />

                <Button
                    android:id="@+id/leftFiveButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Pojam 5" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="8dp">

                <Button
                    android:id="@+id/rightOneButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Odgovor 1"
                    android:layout_marginBottom="8dp" />

                <Button
                    android:id="@+id/rightTwoButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Odgovor 2"
                    android:layout_marginBottom="8dp" />

                <Button
                    android:id="@+id/rightThreeButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Odgovor 3"
                    android:layout_marginBottom="8dp" />

                <Button
                    android:id="@+id/rightFourButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Odgovor 4"
                    android:layout_marginBottom="8dp" />

                <Button
                    android:id="@+id/rightFiveButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Odgovor 5" />

            </LinearLayout>

        </LinearLayout>

        <Button
            android:id="@+id/confirmConnectionButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/confirm_connection"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/score_label"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/playerOneScoreText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/player_one_score"
            android:textSize="18sp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/playerTwoScoreText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/player_two_score"
            android:textSize="18sp" />

    </LinearLayout>

</ScrollView>
