<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/navbar"
    android:layout_width="90dp"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#263238">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:orientation="vertical"
        android:gravity="top"
        android:paddingTop="16dp">

        <LinearLayout
            android:id="@+id/nav_home"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="12dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="10dp"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/navbar_button_background">

            <ImageView
                android:layout_width="@dimen/navbar_icon_size"
                android:layout_height="@dimen/navbar_icon_size"
                android:src="@drawable/home"
                android:scaleType="fitCenter" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="@string/nav_home"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@android:color/white" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_profile"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="12dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="10dp"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/navbar_button_background">

            <ImageView
                android:layout_width="@dimen/navbar_icon_size"
                android:layout_height="@dimen/navbar_icon_size"
                android:src="@drawable/profile"
                android:scaleType="fitCenter" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="@string/nav_profile"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@android:color/white" />

        </LinearLayout>


        <LinearLayout
            android:id="@+id/nav_logout"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="10dp"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/navbar_button_background">

            <ImageView
                android:layout_width="@dimen/navbar_icon_size"
                android:layout_height="@dimen/navbar_icon_size"
                android:src="@drawable/logout"
                android:scaleType="fitCenter" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="@string/nav_logout"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@android:color/white" />

        </LinearLayout>
    </LinearLayout>

    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2" />

</LinearLayout>